#!/bin/sh /etc/rc.common

START=98
USE_PROCD=1

start_service() {
	procd_open_instance
	procd_set_param command /usr/sbin/h5000m-fancontrol daemon
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 0
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger h5000m_fancontrol
}
