#!/bin/sh

schema="$(uci -q get h5000m_fancontrol.settings.schema_version || echo 0)"
case "$schema" in ''|*[!0-9]*) schema=0 ;; esac

if [ "$schema" -lt 2 ]; then
	[ "$(uci -q get h5000m_fancontrol.settings.mode || true)" = "off" ] && \
		uci -q set h5000m_fancontrol.settings.mode='kernel'
	uci -q set h5000m_fancontrol.settings.temp_source='max'
	uci -q set h5000m_fancontrol.settings.interval='5'
	uci -q set h5000m_fancontrol.settings.hysteresis='2'
	uci -q set h5000m_fancontrol.settings.down_delay='30'
	uci -q set h5000m_fancontrol.settings.start_pwm='192'
	uci -q set h5000m_fancontrol.settings.start_boost_ms='700'
	uci -q set h5000m_fancontrol.settings.fail_pwm='255'
	uci -q set h5000m_fancontrol.settings.curve_silent='20:0,35:0,40:50,55:50,70:60,85:75,95:100'
	uci -q set h5000m_fancontrol.settings.curve_balanced='20:0,35:0,40:50,55:60,70:75,85:90,95:100'
	uci -q set h5000m_fancontrol.settings.curve_performance='20:0,30:60,45:70,60:82,75:92,85:100'
	uci -q set h5000m_fancontrol.settings.curve_custom='20:0,40:50,55:60,70:75,85:90,95:100'
	uci -q set h5000m_fancontrol.settings.schema_version='2'
	uci -q delete h5000m_fancontrol.settings.min_pwm
	uci -q delete h5000m_fancontrol.settings.max_pwm
	uci -q delete h5000m_fancontrol.settings.low_temp
	uci -q delete h5000m_fancontrol.settings.high_temp
	uci -q commit h5000m_fancontrol
fi

/etc/init.d/h5000m-fancontrol enable >/dev/null 2>&1 || true
/etc/init.d/h5000m-fancontrol restart >/dev/null 2>&1 || true

exit 0
