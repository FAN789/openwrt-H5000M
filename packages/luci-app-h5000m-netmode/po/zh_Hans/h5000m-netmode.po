msgid "Mobile Network"
msgstr "移动网络"

msgid "Exit Priority"
msgstr "出口优先级"

msgid "Switch the default route priority between wired WAN and the 5G modem."
msgstr "切换有线 WAN 与 5G 模块的默认出口优先级。"

msgid "Exit Mode"
msgstr "出口模式"

msgid "Wired WAN first, 5G fallback"
msgstr "有线 WAN 优先，5G 备用"

msgid "5G modem first, wired WAN fallback"
msgstr "5G 模块优先，有线 WAN 备用"

msgid "Wired WAN only"
msgstr "仅有线 WAN"

msgid "5G modem only"
msgstr "仅 5G 模块"

msgid "Current Status"
msgstr "当前状态"

msgid "Current Mode"
msgstr "当前模式"

msgid "IPv4 Default Route"
msgstr "IPv4 默认出口"

msgid "IPv6 Default Route"
msgstr "IPv6 默认出口"

msgid "Unknown"
msgstr "未知"

msgid "None"
msgstr "无"

msgid "Wired WAN Metric"
msgstr "有线 WAN metric"

msgid "5G Modem Metric"
msgstr "5G 模块 metric"

msgid "Wired WAN Default Route"
msgstr "有线 WAN 默认路由"

msgid "5G Modem Default Route"
msgstr "5G 模块默认路由"

msgid "Disabled"
msgstr "已停用"

msgid "Enabled"
msgstr "开启"

msgid "Exit priority has been applied."
msgstr "出口优先级已应用。"

msgid "Failed to apply exit priority:"
msgstr "出口优先级应用失败："

msgid "Network exits"
msgstr "网络出口"

msgid "Choose how wired WAN and the 5G modem share Internet traffic."
msgstr "设置有线 WAN 与 5G 模块的使用顺序和备用关系。"

msgid "Wired WAN"
msgstr "有线 WAN"

msgid "5G modem"
msgstr "5G 模块"

msgid "Other route"
msgstr "其他路由"

msgid "No available exit"
msgstr "暂无可用出口"

msgid "Only exit"
msgstr "唯一出口"

msgid "Disabled by policy"
msgstr "策略已停用"

msgid "Preferred exit"
msgstr "首选出口"

msgid "Fallback exit"
msgstr "备用出口"

msgid "Not configured"
msgstr "未配置"

msgid "Connected"
msgstr "已连接"

msgid "Disconnected"
msgstr "未连接"

msgid "IPv4 in use"
msgstr "IPv4 使用中"

msgid "IPv4 ready"
msgstr "IPv4 可用"

msgid "IPv4 unavailable"
msgstr "IPv4 不可用"

msgid "IPv6 in use"
msgstr "IPv6 使用中"

msgid "IPv6 ready"
msgstr "IPv6 可用"

msgid "IPv6 unavailable"
msgstr "IPv6 不可用"

msgid "No default route is currently available. Check the cable or 5G connection."
msgstr "当前没有可用的默认出口，请检查网线或 5G 连接。"

msgid "Only %s is enabled by the current policy."
msgstr "当前策略仅启用了 %s。"

msgid "%s is unavailable, so traffic has switched to %s."
msgstr "%s 当前不可用，流量已自动切换到 %s。"

msgid "%s is unavailable, so IPv4 has switched to %s. IPv6 remains disabled to avoid splitting traffic across two exits."
msgstr "%s 当前不可用，IPv4 已自动切换到 %s；为避免双栈分流，备用线路的 IPv6 保持停用。"

msgid "IPv4 is using %s. IPv6 is unavailable on the preferred exit, so fallback IPv6 is disabled to avoid splitting traffic."
msgstr "IPv4 正在使用 %s；首选线路没有可用 IPv6，因此备用线路 IPv6 已自动停用，避免流量分走两条线路。"

msgid "IPv4 and IPv6 are using the preferred exit. The fallback will take over when needed."
msgstr "IPv4 与 IPv6 正在使用首选出口；首选出口不可用时，备用出口会自动接管。"

msgid "Traffic is currently using another default route."
msgstr "流量当前正在使用其他默认路由。"

msgid "Current exit: %s"
msgstr "当前出口：%s"

msgid "IPv4: %s · IPv6: %s"
msgstr "IPv4：%s · IPv6：%s"

msgid "Usage policy"
msgstr "使用策略"

msgid "The preferred exit is used whenever it is available. A fallback exit takes over automatically."
msgstr "首选出口可用时优先使用；首选出口断开后，备用出口会自动接管。"

msgid "Exit policy"
msgstr "出口策略"

msgid "Using only one exit disables automatic fallback."
msgstr "选择“仅使用”模式后不会自动切换到另一条线路。"

msgid "Exit policy applied successfully."
msgstr "出口策略已成功应用。"

msgid "Failed to apply exit policy:"
msgstr "出口策略应用失败："

msgid "Unknown error"
msgstr "未知错误"

msgid "Not selected"
msgstr "未选择"

msgid "Click the connection cards to set the order. The first is preferred and the second is fallback."
msgstr "点击线路卡片设置使用顺序；第一条为首选出口，第二条为备用出口。"

msgid "Apply settings"
msgstr "应用设置"

msgid "Applying…"
msgstr "正在应用…"

msgid "Exit selection applied successfully."
msgstr "出口选择已成功应用。"

msgid "Failed to apply exit selection:"
msgstr "出口选择应用失败："
