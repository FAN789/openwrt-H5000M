{
	"luci-app-h5000m-netmode": {
		"description": "Grant access to H5000M network priority settings",
		"read": {
			"file": {
				"/usr/sbin/h5000m-netmode": [ "exec" ]
			},
			"uci": [ "h5000m_netmode", "network", "mt5700m" ]
		},
		"write": {
			"file": {
				"/usr/sbin/h5000m-netmode": [ "exec" ]
			},
			"uci": [ "h5000m_netmode", "network", "mt5700m" ]
		}
	}
}
